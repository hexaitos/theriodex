<% lang = params["lang"] %>

<div class="guess">
	<% if correct then %>
		<h1><%= I18n.t(:you_guessed_correctly) %></h1>
		<img src="<%= pokemon_info[:sprite] %>">
		<br>
		<p>You guessed <u><%= guess.capitalize %></u> and the Pokémon was <u><%= pokemon_info[:name] %></u>. Well done!</p>
	<% else %>
		<h1><%= I18n.t(:better_luck_next_time) %></h1>
		<img src="<%= pokemon_info[:sprite] %>">
		<br>
		<p>You guessed <u><%= guess.capitalize %></u> but the Pokémon was <u><%= pokemon_info[:name] %></u></p>
	<% end %>
	<br>
	<% unless session[:challenge] %>
		<a href="/<%= lang %>/game/play"><button><%= I18n.t(:play_again) %></button></a>
	<% else %>
		<a href="/<%= lang %>/game/challenge/play"><button>Next Pokémon</button></a>
	<% end %>
</div>
