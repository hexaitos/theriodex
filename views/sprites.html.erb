
<h1>All <%= name %> sprites</h1>
<hr>
<h2>Default sprites</h2>

<div class="all-sprites">
	<% if sprites.dig("front_default") %>
		<figure>
			<img loading="lazy" src="<%= format_sprite(sprites.dig("front_default")) %>">
			<figcaption>Default</figcaption>
		</figure>
	<% end %>
	<% if sprites.dig("front_female") %>
		<figure>
			<img loading="lazy" src="<%= format_sprite(sprites.dig("front_female")) %>">
			<figcaption>Female</figcaption>
		</figure>
	<% end %>
	<% if sprites.dig("front_shiny") %>
		<figure>
			<img loading="lazy" src="<%= format_sprite(sprites.dig("front_shiny")) %>">
			<figcaption>Shiny</figcaption>
		</figure>
	<% end %>
	<% if sprites.dig("front_shiny_female") %>
		<figure>
			<img loading="lazy" src="<%= format_sprite(sprites.dig("front_shiny_female")) %>">
			<figcaption>Shiny Female</figcaption>
		</figure>
	<% end %>
</div>

<hr>

<div class="all-sprites">
	<% sprites["versions"]&.each do | generation, version | %>
		<% unless all_values_nil?(version) %>
			<div class="all-sprites-gen-container">
				<h2>Generation <%= generation.rpartition("-").last.upcase %></h2>
				<br>
				<div class="sprite-gen">
					<% version.each do | name, sprites | %>
						<div class="sprite-version-container">
							<div class="sprite-version-names">
								<% if name == "icons" %>
									<span>Icons</span>
								<% end %>
								<% get_version_names(name).flatten.uniq.each do | version | %>
									<% unless !sprites["front_default"] %>
										<span><%= version %></span>
									<% end %>
								<% end %>
							</div>
							<div class="sprite-version">
								<% if sprites.dig("front_default") %>
									<figure>
										<img class="sprite" src="<%= format_sprite(sprites.dig("front_default")) %>">
										<figcaption>Default</figcaption>
									</figure>
								<% end %>
								<% if sprites.dig("front_female") %>
									<figure>
										<img loading="lazy" src="<%= format_sprite(sprites.dig("front_female")) %>">
										<figcaption>Female</figcaption>
									</figure>
								<% end %>
								<% if sprites.dig("front_shiny") %>
									<figure>
										<img loading="lazy" src="<%= format_sprite(sprites.dig("front_shiny")) %>">
										<figcaption>Shiny</figcaption>
									</figure>
								<% end %>
								<% if sprites.dig("front_shiny_female") %>
									<figure>
										<img loading="lazy" src="<%= format_sprite(sprites.dig("front_shiny_female")) %>">
										<figcaption>Shiny Female</figcaption>
									</figure>
								<% end %>
								<% if sprites.dig("back_default") %>
									<figure>
										<img class="sprite" src="<%= format_sprite(sprites.dig("back_default")) %>">
										<figcaption>Back Default</figcaption>
									</figure>
								<% end %>
								<% if sprites.dig("back_female") %>
									<figure>
										<img loading="lazy" src="<%= format_sprite(sprites.dig("back_female")) %>">
										<figcaption>Back Female</figcaption>
									</figure>
								<% end %>
								<% if sprites.dig("back_shiny") %>
									<figure>
										<img loading="lazy" src="<%= format_sprite(sprites.dig("back_shiny")) %>">
										<figcaption>Back Shiny</figcaption>
									</figure>
								<% end %>
								<% if sprites.dig("back_shiny_female") %>
									<figure>
										<img loading="lazy" src="<%= format_sprite(sprites.dig("back_shiny_female")) %>">
										<figcaption>Back Shiny Female</figcaption>
									</figure>
								<% end %>
							</div>
						</div>
					<% end %>
				</div>
				<br>
			</div>
		<% end %>
	<% end %>
</div>
