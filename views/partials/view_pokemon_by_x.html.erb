<div class="pokemom-list-container">
	<div class="pokemon-list">
		<% list.each do | id, info | %>
			<% puts info %>
			<div class="pokemon search">
				<div class="id-container">
					<% id.to_s.chars.map(&:to_i).each do | num | %>
						<span><%= num %></span>
					<% end %>
				</div>
				<div class="type-container">
				<% info[:types].each do |id, name| %>
					<a style="text-decoration: none;" href="/<%= lang %>/show/pokemon/type/<%= id %>" aria-label="Pokémon type <%= id %>">
					<div id="<%= id %>" class="move-type-card move-type-card-name rounded"></div>
					</a>
				<% end %>
				</div>
				<br>
				<a href="/<%= lang %>/show/<%= id %>">
					<img loading="lazy" src="<%= info[:sprite] %>" alt="The sprite for the Pokémon <%= info[:name] %>">
					<br>
					<%= info[:name] %>
					<br>
				</a>
				<a class="test" href="/<%= lang %>/show/pokemon/gen/<%= info.dig(:gen, 1) %>"><%= info.dig(:gen, 0) %></a>
				<br>
			</div>
		<% end %>
	</div>
</div>
